{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/criar/retomar/:token", "destination": "/retomar.html?token=:token" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
