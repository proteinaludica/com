{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/criar/retomar/(.*)",
      "destination": "https://criar.proteinaludica.com/retomar/$1",
      "permanent": true
    },
    {
      "source": "/criar",
      "destination": "https://criar.proteinaludica.com",
      "permanent": true
    }
  ]
}
